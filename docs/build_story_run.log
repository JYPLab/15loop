     1	import curriculumJson from "../data/curriculum/ko-2022-basic-words.json";
     2	import type {
     3	  CurriculumTier,
     4	  CurriculumWord,
     5	  CurriculumWordDataset,
     6	} from "../data/curriculum/types";
     7	
     8	const curriculum = curriculumJson as CurriculumWordDataset;
     9	
    10	const normalizedForm = (value: string) => value.trim().toLowerCase();
    11	
    12	const curriculumByForm = new Map<string, CurriculumWord>();
    13	
    14	for (const item of curriculum.words) {
    15	  for (const form of [item.lemma, ...item.aliases, ...item.relatedForms]) {
    16	    const normalized = normalizedForm(form);
    17	    if (normalized && !curriculumByForm.has(normalized)) {
    18	      curriculumByForm.set(normalized, item);
    19	    }
    20	  }
    21	}
    22	
    23	export const curriculumSummary = {
    24	  curriculum: curriculum.metadata.curriculum,
    25	  sourceId: curriculum.metadata.sourceId,
    26	  sourceUrl: curriculum.metadata.sourceUrl,
    27	  counts: curriculum.metadata.counts,
    28	} as const;
    29	
    30	export function findCurriculumWord(form: string) {
    31	  return curriculumByForm.get(normalizedForm(form)) ?? null;
    32	}
    33	
    34	export function summarizeCurriculumCoverage(forms: string[]) {
    35	  const byTier: Record<CurriculumTier, number> = {
    36	    elementary: 0,
    37	    "secondary-common": 0,
    38	    advanced: 0,
    39	  };
    40	  const missing: string[] = [];
    41	
    42	  for (const form of new Set(forms.map(normalizedForm).filter(Boolean))) {
    43	    const match = findCurriculumWord(form);
    44	    if (match) byTier[match.tier] += 1;
    45	    else missing.push(form);
    46	  }
    47	
    48	  const matched = Object.values(byTier).reduce((sum, count) => sum + count, 0);
    49	  return {
    50	    total: matched + missing.length,
    51	    matched,
    52	    missing,
    53	    byTier,
    54	  };
    55	}

