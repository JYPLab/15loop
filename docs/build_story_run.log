    23	        email: parent.email,
    24	        displayName: parent.displayName,
    25	        updatedAt: new Date().toISOString(),
    26	      }).where(eq(schema.guardianAccounts.id, parent.id)).returning();
    27	      return updated;
    28	    }
    29	    return existing;
    30	  }
    31	
    32	  const now = new Date();
    33	  const trialEnd = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);
    34	  const [created] = await db.insert(schema.guardianAccounts).values({
    35	    id: parent.id,
    36	    email: parent.email,
    37	    displayName: parent.displayName,
    38	    customerKey: `guardian-${crypto.randomUUID()}`,
    39	    trialStartedAt: now.toISOString(),
    40	    trialEndsAt: trialEnd.toISOString(),
    41	  }).returning();
    42	  return created;
