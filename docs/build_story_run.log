   106	function scoreAnswers(answers: Answer[]): ScoreMap {
   107	  return skillOrder.reduce((scores, skill) => {
   108	    const items = answers.filter((answer) => answer.skill === skill);
   109	    scores[skill] = items.length
   110	      ? Math.round((items.filter((answer) => answer.correct).length / items.length) * 100)
   111	      : 0;
   112	    return scores;
   113	  }, { see: 0, hear: 0, context: 0, recall: 0 } as ScoreMap);
   114	}
   115	
   116	function levelFrom(scores: ScoreMap) {
   117	  const overall = Math.round(skillOrder.reduce((sum, skill) => sum + scores[skill], 0) / skillOrder.length);
   118	  if (overall < 45) return "foundation";
   119	  if (overall < 75) return "developing";
   120	  return "school-ready";
   121	}
   122	
   123	function choiceValues(question: Question) {
   124	  if (question.skill === "see") return [question.word.meaningKo, ...question.word.distractorsKo];
   125	  if (question.skill === "hear") return question.word.soundChoices;
   126	  if (question.skill === "context") return question.word.contextChoices;
   127	  return [];
   128	}
   129	
   130	function correctValue(question: Question) {
   131	  if (question.skill === "see") return question.word.meaningKo;
   132	  if (question.skill === "hear") return question.word.word;
   133	  if (question.skill === "context") return question.word.contextChoices[0];
   134	  return question.word.word;
   135	}
